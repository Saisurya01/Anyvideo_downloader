{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "nixpacks": {
      "image": "nodejs_18",
      "aptPackages": ["ffmpeg"],
      "pipPackage": "yt-dlp"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "preDeployCommand": "npm install && cd video-downloader && npm install && cd server && npm install && cd ../.. && npm run build",
    "startCommand": "node server.js"
  }
}
